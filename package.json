{
  "name": "glowdeck",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:dev": "next build && electron .",
    "electron:build": "next build && electron-builder --config electron/electron-builder.config.js",
    "electron:build:win": "npm run electron:build -- --win",
    "electron:build:mac": "npm run electron:build -- --mac"
  },
  "dependencies": {
    "idb-keyval": "^6.2.2",
    "nanoid": "^5.1.7",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-grid-layout": "^2.2.3",
    "react-player": "^3.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "electron-updater": "^6.6.0",
    "vitest": "^4.1.3"
  }
}
