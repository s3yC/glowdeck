# GlowDeck Environment Variables
# Copy to .env.local and fill in values as needed

# ============================================
# MVP — No keys required
# All free-tier integrations use keyless iframe embeds or open APIs
# ============================================

# ============================================
# Post-MVP — Google Calendar OAuth (private calendars)
# ============================================
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id
# GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# ============================================
# Post-MVP — Stripe (premium subscriptions)
# ============================================
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================
# Post-MVP — Analytics (optional)
# ============================================
# NEXT_PUBLIC_ANALYTICS_ID=your-analytics-id
